   "source": [
    "N = int(input())\n",
    "S = [int(input()) for i in range(N)]\n",
    "#print(S)\n",
    "S.sort()\n",
    "ans = sum(S)\n",
    "i = 0\n",
    "while ans % 10 == 0 and ans != 0:\n",
    "    ans -= S[i]\n",
    "    i += 1\n",
    "    #print(f'i: {i}, ans: {ans}')\n",
    "print(ans)"
   ]
