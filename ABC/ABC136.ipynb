   "source": [
    "S = list(input())\n",
    "d = [0] * len(S)\n",
    "for i in range(len(S) - 1):\n",
    "    if S[i + 1] == 'R' and S[i] == 'L':\n",
    "        d[i] = -1\n",
    "    elif S[i + 1] == 'L' and S[i] == 'R':\n",
    "        d[i] = 1\n",
    "print(d)\n"
   ]
