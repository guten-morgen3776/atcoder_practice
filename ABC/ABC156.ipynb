   "source": [
    "N = int(input())\n",
    "X = list(map(int, input().split()))\n",
    "min_cost = 10 ** 1000\n",
    "for i in range(100):\n",
    "    cost = 0\n",
    "    for x in X:\n",
    "        cost += (x - i) ** 2\n",
    "    if cost <= min_cost:\n",
    "        min_cost = cost\n",
    "print(min_cost)"
   ]
  }
