   "source": [
    "K, N = map(int, input().split())\n",
    "A = list(map(int, input().split()))\n",
    "for i in range(N):\n",
    "    A.append(A[i] + K)\n",
    "\n",
    "ans = float('inf')\n",
    "for j in range(N + 1):\n",
    "    start = A[j]\n",
    "    end = A[j + N - 1]\n",
    "    if ans > end - start:\n",
    "        ans = end - start\n",
    "print(ans)"
   ]
  },
