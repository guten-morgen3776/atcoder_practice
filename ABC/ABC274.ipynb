   "source": [
    "N = int(input())\n",
    "A = list(map(int, input().split()))\n",
    "\n",
    "ans = [0] * (2 * N + 2)\n",
    "for i in range (1, N + 1):\n",
    "    ans[2 * i] = ans[A[i - 1]] + 1\n",
    "    ans[2 * i + 1] = ans[A[i - 1]] + 1\n",
    "\n",
    "for j in range(1, 2 * N + 2):\n",
    "    print(ans[j])"
   ]
  }
