   "source": [
    "from functools import lru_cache\n",
    "\n",
    "@lru_cache\n",
    "def f(n):\n",
    "    if n == 0:\n",
    "        return 1\n",
    "    return f(n // 2) + f(n // 3)\n",
    "\n",
    "print(f(int(input())))\n"
   ]
  },
