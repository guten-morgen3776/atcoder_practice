    "    f_s = list(map(int, input().split()))\n",
    "    flavors.append(f_s)\n",
    "import numpy as np\n",
    "flavors = np.array(flavors)\n",
    "manzoku = flavors[:, 1]\n",
    "manzoku_max = manzoku.max()\n",
    "manzoku_max_idx = np.argmax(manzoku)\n"
   ]
