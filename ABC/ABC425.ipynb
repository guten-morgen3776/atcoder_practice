   "source": [
    "N, Q = map(int, input().split())\n",
    "A = list(map(int, input().split()))\n",
    "B = A * 2\n",
    "\"\"\"\n",
    "テクニック\n",
    "・配列の2重化：循環する配列の扱い\n",
    "・累積和：区間の合計値を高速に計算するためにあらかじめ合計値を計算しておく\n",
    "\"\"\"\n",
    "for i in range(2 * N - 1, 0, -1):\n",
    "    B[i - 1] += B[i]\n",
    "\n",
    "\n",
    "\n"
   ]
