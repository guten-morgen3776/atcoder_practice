   "source": [
    "N = int(input())\n",
    "A = list(map(int, input().split()))\n",
    "B = list(map(int, input().split()))\n",
    "dp = [0] * (N + 1)\n",
    "dp[1] = 0\n",
    "dp[2] = A[0]\n",
    "for i in range(3, N + 1):\n",
    "    dp[i] = min(dp[i - 2] + B[i - 3], dp[i - 1] + A[i - 2])\n",
    "print(dp[N])\n"
   ]
  }
 ],
