   "source": [
    "Q = int(input())\n",
    "from collections import deque\n",
    "s = deque()\n",
    "for _ in range(Q):\n",
    "    que = list(input().split())\n",
    "    #print(que)\n",
    "    #print(s)\n",
    "    if int(que[0]) == 1:\n",
    "        s.append(que[1])\n",
    "    elif int(que[0]) == 2:\n",
    "        print(s[-1]) #-1で一番右の要素を返す\n",
    "    else:\n",
    "        s.pop()\n"
   ]
  }
 ],
