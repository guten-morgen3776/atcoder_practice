   "source": [
    "N = int(input())\n",
    "A = list(map(int, input().split()))\n",
    "Q = int(input())\n",
    "A_sort = sorted(A)\n",
    "\n",
    "import bisect\n",
    "for _ in range(Q):\n",
    "    x = int(input())\n",
    "    print(bisect.bisect_left(A_sort, x))\n",
    "\n"
   ]
  }
